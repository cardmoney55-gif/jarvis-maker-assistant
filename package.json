{
  "name": "jarvis-desktop",
  "private": true,
  "version": "4.1.0",
  "type": "module",
  "description": "J.A.R.V.I.S. — Autonomous DIY Maker Assistant (Desktop Edition)",
  "author": "JARVIS Lab",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rimraf dist dist-electron release",
    "lint": "tsc --noEmit",
    "electron:dev": "electron .",
    "build:frontend": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --target=node18 --external:vite --outfile=dist-electron/server.cjs",
    "dist": "npm run build:frontend && npm run build:server && electron-builder",
    "dist:win": "npm run build:frontend && npm run build:server && electron-builder --win",
    "pack": "npm run build:frontend && npm run build:server && electron-builder --dir"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "three": "^0.171.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.jarvis.maker.assistant",
    "productName": "JARVIS Maker Assistant",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "app-dist"
      },
      {
        "from": "dist-electron/server.cjs",
        "to": "server.cjs"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "JARVIS-Maker-Assistant-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JARVIS Maker Assistant"
    },
    "portable": {
      "artifactName": "JARVIS-Maker-Assistant-${version}-portable.${ext}"
    }
  }
}
